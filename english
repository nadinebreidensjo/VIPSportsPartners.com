<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VIP Sports Partners – Global Sponsorship & Exclusive Sports Travel</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#0C0C10;
  --ink2:#13131A;
  --ink3:#1C1C26;
  --ink4:#252532;
  --gold:#B8963E;
  --gold2:#D4B06A;
  --offwhite:#F5F2EC;
  --muted:#6B6B7E;
  --muted2:#9898A8;
  --r:3px;
}
html{scroll-behavior:smooth}
body{font-family:'Outfit',sans-serif;background:var(--ink);color:var(--offwhite);font-size:16px;line-height:1.65;overflow-x:hidden}

nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 52px;height:68px;
  background:rgba(12,12,16,0.96);
  backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(184,150,62,0.12);
}
.logo{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--offwhite);text-decoration:none;white-space:nowrap}
.logo em{color:var(--gold);font-style:normal}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);text-decoration:none;font-weight:400;transition:color 0.2s}
.nav-links a:hover{color:var(--gold)}
.nav-btn{font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:600;padding:11px 26px;background:transparent;color:var(--gold);border:1px solid var(--gold);cursor:pointer;border-radius:var(--r);text-decoration:none;transition:all 0.2s;white-space:nowrap}
.nav-btn:hover{background:var(--gold);color:var(--ink)}

.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:120px 52px 80px;position:relative;overflow:hidden}
.hero-grid{position:absolute;inset:0;background:repeating-linear-gradient(90deg,rgba(184,150,62,0.035) 0,rgba(184,150,62,0.035) 1px,transparent 1px,transparent 120px),repeating-linear-gradient(0deg,rgba(184,150,62,0.035) 0,rgba(184,150,62,0.035) 1px,transparent 1px,transparent 120px)}
.hero-glow{position:absolute;top:-200px;right:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(184,150,62,0.07) 0%,transparent 65%);pointer-events:none}
.hero-eyebrow{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:28px;display:flex;align-items:center;gap:14px}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:36px;height:1px;background:var(--gold)}
h1{font-family:'Cormorant Garamond',serif;font-size:clamp(52px,7.5vw,108px);font-weight:500;line-height:1.0;letter-spacing:-1px;margin-bottom:36px;position:relative}
h1 .accent{color:var(--gold);font-style:italic}
.hero-body{font-size:17px;color:rgba(245,242,236,0.6);max-width:540px;line-height:1.8;margin-bottom:48px;font-weight:300;position:relative}
.hero-actions{display:flex;align-items:center;gap:28px;position:relative}
.btn-gold{font-size:11px;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;padding:16px 40px;background:var(--gold);color:var(--ink);border:none;cursor:pointer;border-radius:var(--r);text-decoration:none;transition:background 0.2s,transform 0.15s;display:inline-block}
.btn-gold:hover{background:var(--gold2);transform:translateY(-1px)}
.btn-ghost{font-size:12px;color:var(--muted2);text-decoration:none;letter-spacing:1px;display:flex;align-items:center;gap:8px;transition:color 0.2s}
.btn-ghost:hover{color:var(--offwhite)}
.btn-ghost::after{content:'→';transition:transform 0.2s}
.btn-ghost:hover::after{transform:translateX(4px)}
.hero-kpi{position:absolute;right:52px;bottom:80px;display:grid;grid-template-columns:1fr 1fr;gap:2px}
.kpi-box{background:rgba(28,28,38,0.85);border:1px solid rgba(184,150,62,0.1);padding:24px 28px}
.kpi-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:500;color:var(--gold);line-height:1;margin-bottom:4px;letter-spacing:1px}
.kpi-lbl{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:400}

.ticker-wrap{background:var(--ink2);padding:18px 0;overflow:hidden;border-top:1px solid rgba(184,150,62,0.08);border-bottom:1px solid rgba(184,150,62,0.08)}
.ticker{display:flex;animation:tick 34s linear infinite;width:max-content}
.ticker-item{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:rgba(184,150,62,0.35);padding:0 40px;border-right:1px solid rgba(184,150,62,0.12);white-space:nowrap;font-weight:500;transition:color 0.2s;cursor:default}
.ticker-item:hover{color:var(--gold)}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

section{padding:110px 52px}
.sec-label{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:20px}
h2.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,4.5vw,64px);font-weight:500;letter-spacing:-0.5px;line-height:1.05;margin-bottom:20px}
h2.sec-title em{color:var(--gold);font-style:italic}
.sec-body{font-size:16px;color:var(--muted2);max-width:560px;line-height:1.8;margin-bottom:64px;font-weight:300}

/* GLOBAL REACH */
.global-section{background:var(--ink2)}
.global-intro{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-bottom:64px}
.global-map{background:var(--ink3);border:1px solid rgba(184,150,62,0.1);padding:48px;position:relative;overflow:hidden}
.world-svg{width:100%;opacity:0.7}
.region-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(184,150,62,0.08)}
.region-card{background:var(--ink2);padding:28px 24px;transition:background 0.3s}
.region-card:hover{background:var(--ink3)}
.region-name{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;margin-bottom:8px;line-height:1}
.region-leagues{font-size:12px;color:var(--muted);line-height:1.7;font-weight:300}
.region-dot{width:6px;height:6px;background:var(--gold);border-radius:50%;margin-bottom:12px}

/* TRUST */
.trust-section{background:var(--ink)}
.trust-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(184,150,62,0.08);margin-bottom:64px}
.trust-card{background:var(--ink);padding:44px 40px;display:flex;flex-direction:column;transition:background 0.3s}
.trust-card:hover{background:var(--ink2)}
.trust-num{font-family:'Cormorant Garamond',serif;font-size:64px;font-weight:500;color:var(--gold);line-height:1;margin-bottom:8px;letter-spacing:1px}
.trust-label{font-size:13px;font-weight:500;color:var(--offwhite);margin-bottom:10px;letter-spacing:0.5px}
.trust-desc{font-size:13px;color:var(--muted);line-height:1.7;font-weight:300}
.trust-quote{background:var(--ink2);border-left:2px solid var(--gold);padding:36px 48px}
.trust-quote p{font-family:'Cormorant Garamond',serif;font-size:22px;font-style:italic;color:var(--offwhite);line-height:1.6;margin-bottom:20px;font-weight:400}
.trust-quote cite{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-style:normal;font-weight:500}

/* INDUSTRIES */
.industries{background:var(--ink2)}
.ind-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,0.04)}
.ind-card{background:var(--ink2);padding:40px 32px;border-top:2px solid transparent;transition:all 0.3s;display:flex;flex-direction:column}
.ind-card:hover{background:var(--ink3);border-top-color:var(--gold)}
.ind-icon{font-size:26px;margin-bottom:20px;display:block}
.ind-name{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:500;margin-bottom:12px;line-height:1}
.ind-desc{font-size:13px;color:var(--muted);line-height:1.7;font-weight:300;flex:1}
.ind-examples{margin-top:20px;font-size:11px;color:rgba(184,150,62,0.6);letter-spacing:1px;text-transform:uppercase;font-weight:500}

/* PACKAGES */
.pkg-section{background:var(--ink3)}
.pkg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(184,150,62,0.08)}
.pkg{background:var(--ink3);padding:48px 40px;position:relative;transition:background 0.3s;display:flex;flex-direction:column}
.pkg:hover,.pkg.featured{background:var(--ink4)}
.pkg.featured{border-top:2px solid var(--gold)}
.pkg-tier{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--muted);font-weight:500;margin-bottom:16px}
.pkg-name{font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:500;color:var(--offwhite);margin-bottom:8px;line-height:1}
.pkg-sub{font-size:13px;color:var(--muted);margin-bottom:32px;font-weight:300;font-style:italic}
.pkg-value-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:12px}
.pkg-value-text{font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:rgba(245,242,236,0.85);line-height:1.6;margin-bottom:32px;font-weight:400}
.pkg-list{list-style:none;flex:1}
.pkg-list li{padding:11px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;color:rgba(245,242,236,0.75);display:flex;align-items:flex-start;gap:10px;line-height:1.5;font-weight:300}
.pkg-list li::before{content:'–';color:var(--gold);flex-shrink:0;margin-top:1px}
.pkg-cta{display:block;text-align:center;padding:15px 24px;border:1px solid rgba(184,150,62,0.35);color:var(--gold);text-decoration:none;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;border-radius:var(--r);transition:all 0.2s;margin-top:36px}
.pkg.featured .pkg-cta{background:var(--gold);color:var(--ink);border-color:var(--gold)}
.pkg-cta:hover{background:var(--gold);color:var(--ink);border-color:var(--gold)}
.pkg-badge{position:absolute;top:20px;right:20px;font-size:9px;letter-spacing:2px;text-transform:uppercase;background:rgba(184,150,62,0.15);color:var(--gold);padding:5px 12px;border-radius:2px;border:1px solid rgba(184,150,62,0.25);font-weight:600}

/* MOTORSPORT */
.moto-block{background:rgba(184,150,62,0.08);margin-top:1px}
.moto-inner{background:var(--ink3);padding:48px 40px}
.moto-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.moto-sub-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(184,150,62,0.08)}
.moto-card{background:var(--ink4);padding:28px 24px}
.moto-card-tag{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:10px}
.moto-card-name{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;margin-bottom:8px}
.moto-card-desc{font-size:12px;color:var(--muted);font-weight:300;line-height:1.6}

/* EXPOSURE */
.exposure{background:var(--ink)}
.exp-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.shirt-mock{background:var(--ink3);border:1px solid rgba(184,150,62,0.1);padding:60px 40px;text-align:center;aspect-ratio:3/4;display:flex;flex-direction:column;align-items:center;justify-content:center}
.shirt-shape{width:200px;height:220px;background:var(--ink4);clip-path:polygon(20% 0%,80% 0%,100% 15%,90% 100%,10% 100%,0% 15%);display:flex;align-items:center;justify-content:center}
.shirt-logo-zone{background:rgba(184,150,62,0.15);border:1px dashed rgba(184,150,62,0.4);padding:12px 20px;border-radius:2px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);font-weight:600}
.exp-placements{display:flex;flex-direction:column;gap:0;margin-bottom:36px}
.ep{display:flex;align-items:center;justify-content:space-between;padding:17px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.ep-left{flex:1}
.ep-name{font-size:14px;font-weight:400;color:var(--offwhite);margin-bottom:3px}
.ep-reach{font-size:12px;color:var(--muted);font-weight:300}
.ep-bar{width:80px;height:3px;background:rgba(184,150,62,0.1);border-radius:2px;overflow:hidden;flex-shrink:0;margin-left:20px}
.ep-fill{height:100%;background:var(--gold);border-radius:2px}
.exp-roi{background:var(--ink3);border:1px solid rgba(184,150,62,0.15);padding:28px 32px}
.exp-roi-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:12px}
.exp-roi-text{font-family:'Cormorant Garamond',serif;font-size:19px;font-style:italic;color:rgba(245,242,236,0.85);line-height:1.6;font-weight:400}

/* TRIPS */
.trips-section{background:var(--ink2)}
.trips-layout{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(184,150,62,0.06)}
.trip{background:var(--ink2);padding:52px 48px 90px;position:relative;overflow:hidden;transition:background 0.3s;display:flex;flex-direction:column}
.trip:hover{background:var(--ink3)}
.trip.span2{grid-column:span 2;padding:72px 48px 100px}
.trip-sport{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.trip-sport::before{content:'';width:24px;height:1px;background:var(--gold)}
.trip-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,3vw,44px);font-weight:500;line-height:1.1;margin-bottom:14px}
.trip.span2 .trip-title{font-size:clamp(34px,4vw,60px)}
.trip-meta{display:flex;flex-wrap:wrap;gap:20px;font-size:12px;color:var(--muted);margin-bottom:16px;font-weight:300}
.trip-desc{font-size:13px;color:var(--muted2);line-height:1.7;font-weight:300;margin-bottom:0;flex:1;max-width:460px}
.trip-from{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:500;color:var(--offwhite);margin-top:auto;padding-top:24px}
.trip-from small{font-family:'Outfit',sans-serif;font-size:12px;color:var(--muted);font-weight:300;margin-left:6px}
.trip-corner{position:absolute;bottom:44px;right:44px;width:52px;height:52px;border:1px solid rgba(184,150,62,0.25);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:18px;transition:all 0.2s;cursor:pointer;text-decoration:none}
.trip:hover .trip-corner{background:var(--gold);color:var(--ink);border-color:var(--gold)}
.trip-secret{background:var(--ink);border:1px solid rgba(184,150,62,0.2);padding:52px 48px;grid-column:span 2;display:flex;align-items:center;justify-content:space-between;gap:40px}
.trip-secret-text h3{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:500;margin-bottom:14px;line-height:1.1}
.trip-secret-text p{font-size:14px;color:var(--muted2);line-height:1.75;font-weight:300;max-width:580px}
.trip-secret-cta{flex-shrink:0}

/* CONTACT */
.contact-s{background:var(--ink3)}
.contact-layout{display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:start}
.contact-left p{font-size:15px;color:var(--muted2);line-height:1.85;margin-bottom:48px;font-weight:300}
.contact-points{display:flex;flex-direction:column}
.cp{padding:20px 0;border-bottom:1px solid rgba(255,255,255,0.04);display:flex;gap:20px;align-items:center}
.cp-ico{width:44px;height:44px;flex-shrink:0;background:rgba(184,150,62,0.08);border:1px solid rgba(184,150,62,0.15);border-radius:var(--r);display:flex;align-items:center;justify-content:center;font-size:16px}
.cp strong{font-size:13px;display:block;font-weight:500;margin-bottom:3px}
.cp span{font-size:13px;color:var(--muted);font-weight:300}
.contact-form{display:flex;flex-direction:column;gap:20px}
.cf-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.cf-group{display:flex;flex-direction:column;gap:8px}
.cf-group label{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);font-weight:500}
.cf-group input,.cf-group select,.cf-group textarea{background:var(--ink2);border:1px solid rgba(255,255,255,0.07);color:var(--offwhite);padding:14px 18px;font-size:14px;font-family:'Outfit',sans-serif;border-radius:var(--r);outline:none;transition:border-color 0.2s;font-weight:300;width:100%}
.cf-group input:focus,.cf-group select:focus,.cf-group textarea:focus{border-color:rgba(184,150,62,0.5)}
.cf-group input::placeholder,.cf-group textarea::placeholder{color:var(--muted);font-weight:300}
.cf-group select option{background:var(--ink2)}
.cf-group textarea{min-height:110px;resize:vertical}

/* FOOTER */
footer{background:var(--ink2);padding:64px 52px 32px;border-top:1px solid rgba(184,150,62,0.1)}
.footer-top{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:60px;margin-bottom:56px}
.footer-desc{font-size:13px;color:var(--muted);line-height:1.8;max-width:260px;font-weight:300;margin-top:16px}
.footer-col h5{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--offwhite);margin-bottom:22px;font-weight:500}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:12px}
.footer-links a{font-size:13px;color:var(--muted);text-decoration:none;transition:color 0.2s;font-weight:300}
.footer-links a:hover{color:var(--gold)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:24px;border-top:1px solid rgba(255,255,255,0.05)}
.footer-bottom p{font-size:12px;color:var(--muted);font-weight:300}

@media(max-width:960px){
  nav{padding:0 20px}
  .nav-links{display:none}
  section{padding:64px 20px}
  .hero{padding:100px 20px 60px}
  .hero-kpi{display:none}
  .global-intro,.trust-grid,.pkg-grid,.ind-grid,.region-grid,.exp-grid,.moto-grid,.contact-layout{grid-template-columns:1fr}
  .global-intro{gap:40px}
  .exp-grid{gap:48px}
  .trips-layout{grid-template-columns:1fr}
  .trip.span2,.trip-secret{grid-column:span 1}
  .trip-secret{flex-direction:column;gap:24px}
  .footer-top{grid-template-columns:1fr 1fr;gap:32px}
  .moto-grid{gap:40px}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="logo">VIP<em>Sports</em>Partners</a>
  <ul class="nav-links">
    <li><a href="#sponsorship">Sponsorship</a></li>
    <li><a href="#travel">Sports Travel</a></li>
    <li><a href="#industries">Industries</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="nav-btn">Book a Meeting</a>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-eyebrow">Global Sponsorship &amp; Sports Travel</div>
  <h1>
    Your brand.<br>
    <span class="accent">Every arena.</span><br>
    Every market.
  </h1>
  <p class="hero-body">We place the world's most ambitious companies at the centre of the world's most-watched sporting events — on shirts, on circuits, on stadium facades. From Stockholm to Singapore. No venue is off-limits.</p>
  <div class="hero-actions">
    <a href="#sponsorship" class="btn-gold">Explore Sponsorship</a>
    <a href="#travel" class="btn-ghost">Exclusive Sports Travel</a>
  </div>
  <div class="hero-kpi">
    <div class="kpi-box"><div class="kpi-num">15+</div><div class="kpi-lbl">Years in the field</div></div>
    <div class="kpi-box"><div class="kpi-num">200+</div><div class="kpi-lbl">Global partners</div></div>
    <div class="kpi-box"><div class="kpi-num">60+</div><div class="kpi-lbl">Countries</div></div>
    <div class="kpi-box"><div class="kpi-num">3.2bn</div><div class="kpi-lbl">Viewers reached</div></div>
  </div>
</section>

<!-- TICKER -->
<div class="ticker-wrap">
